###################################################################################################
# mod-playerbots-cata — worldserver module configuration
#
# Copy to configs/mods/mod-playerbots-cata.conf (same directory as other module configs after install
# or build output) and adjust values. Keys are merged into the global ConfigMgr map.
#
# MySQL connection for the dedicated playerbots database is configured in worldserver.conf:
#   PlayerbotsDatabaseInfo, PlayerbotsDatabase.WorkerThreads, PlayerbotsDatabase.SynchThreads
# and update mask bit DATABASE_PLAYERBOTS (Updates.EnableDatabases, value 16).
###################################################################################################

#
#    Playerbots.Enable
#        Description: Master switch for the playerbots module (Phase 1: logging and hooks only).
#        Default:     0 - (disabled)

Playerbots.Enable = 0

#
#    Playerbots.LogOnStartup
#        Description: When enabled and Playerbots.Enable is 1, emit a short startup line after the
#                     world is marked ready.
#        Default:     1 - (enabled)

Playerbots.LogOnStartup = 1

#
#    Playerbots.AccountPrefix
#        Description: ASCII prefix for generated bot login names (AccountMgr enforces max length 16).
#        Default:     PB

Playerbots.AccountPrefix = PB

#
#    Playerbots.AccountRandomSuffixLength
#        Description: Number of random hex digits after the prefix (underscore added if prefix is non-empty).
#        Default:     8

Playerbots.AccountRandomSuffixLength = 8

#
#    Playerbots.MaxAccountCreateAttempts
#        Description: Retries when a generated account name already exists.
#        Default:     32

Playerbots.MaxAccountCreateAttempts = 32

#
#    Playerbots.MaxCharacterCreateAttempts
#        Description: Outer retries for random race/class/name/appearance when creation fails.
#        Default:     48

Playerbots.MaxCharacterCreateAttempts = 48

#
#    Playerbots.AutoLoginOnStartup
#        Description: After world startup (short delay), log in every active row from
#                     playerbots_bot (status=2, character_guid set). Use 0 for manual
#                     `.playerbots login all` only (safer on dev realms).
#        Default:     0 - (disabled)

Playerbots.AutoLoginOnStartup = 0

#
#    Playerbots.DevBatchMax
#        Description: Maximum count for `.playerbots batch <n>` (dev/test safety).
#        Default:     50  (hard-clamped 1..500 in code)

Playerbots.DevBatchMax = 50

#
#    Playerbots.IdleMovement.Enable
#        Description: Random idle / short nearby wander for managed headless bots (no combat AI).
#        Default:     1 - (enabled)

Playerbots.IdleMovement.Enable = 1

#
#    Playerbots.IdleMovement.UpdateIntervalMs
#        Description: How often the idle controller runs logic per bot (throttle; not packet rate).
#        Default:     250  (clamped 100..2000)

Playerbots.IdleMovement.UpdateIntervalMs = 250

#
#    Playerbots.IdleMovement.MinActionDelayMs / MaxActionDelayMs
#        Description: Random delay after a passive action (facing) before the next idle decision.
#        Default:     4000 / 14000

Playerbots.IdleMovement.MinActionDelayMs = 4000
Playerbots.IdleMovement.MaxActionDelayMs = 14000

#
#    Playerbots.IdleMovement.PostMovePauseMinMs / PostMovePauseMaxMs
#        Description: Pause after finishing a short wander spline before the next decision.
#        Default:     2500 / 8000

Playerbots.IdleMovement.PostMovePauseMinMs = 2500
Playerbots.IdleMovement.PostMovePauseMaxMs = 8000

#
#    Playerbots.IdleMovement.DistractMinMs / DistractMaxMs
#        Description: Duration for MoveDistract (stand / look-around idle).
#        Default:     2500 / 6000

Playerbots.IdleMovement.DistractMinMs = 2500
Playerbots.IdleMovement.DistractMaxMs = 6000

#
#    Playerbots.IdleMovement.WanderRadiusYards
#        Description: Max horizontal distance from the wander anchor (re-anchored after each walk).
#        Default:     12  (clamped 3..40)

Playerbots.IdleMovement.WanderRadiusYards = 12

#
#    Playerbots.IdleMovement.MinStepYards / MaxStepYards
#        Description: Length of each random relocation (2D from anchor). Max is clamped to radius.
#        Default:     2 / 7

Playerbots.IdleMovement.MinStepYards = 2
Playerbots.IdleMovement.MaxStepYards = 7

#
#    Playerbots.IdleMovement.ChanceFacePct / ChanceDistractPct
#        Description: On each idle tick, probability weights (0..100). Remainder = try short walk.
#                     If face + distract > 100, distract is reduced in code.
#        Default:     35 / 25

Playerbots.IdleMovement.ChanceFacePct = 35
Playerbots.IdleMovement.ChanceDistractPct = 25

#
#    Playerbots.TargetSelection.Enable
#        Description: Periodically pick a nearby hostile creature (creatures only); sets UNIT_FIELD_TARGET.
#                     Does not attack. Rescan pauses while the bot is in combat (selection kept).
#        Default:     1

Playerbots.TargetSelection.Enable = 1

#
#    Playerbots.TargetSelection.UpdateIntervalMs
#        Description: Minimum time between rescans per bot (100..5000).
#        Default:     500

Playerbots.TargetSelection.UpdateIntervalMs = 500

#
#    Playerbots.TargetSelection.SearchRadiusYards
#        Description: Grid search radius for candidates (5..60). Nearest valid creature wins.
#        Default:     25

Playerbots.TargetSelection.SearchRadiusYards = 25

#
#    Playerbots.TargetSelection.MaxLevelDelta
#        Description: Skip creatures more than this many levels above the bot (0 = disable check).
#        Default:     5

Playerbots.TargetSelection.MaxLevelDelta = 5

#
#    Playerbots.TargetSelection.SkipElites
#        Description: Skip CREATURE_ELITE_ELITE, RAREELITE, and WORLDBOSS ranks.
#        Default:     1

Playerbots.TargetSelection.SkipElites = 1

#
#    Playerbots.TargetSelection.SkipBossFlag / SkipDungeonBoss
#        Description: Skip CREATURE_TYPE_FLAG_BOSS_MOB and CREATURE_FLAG_EXTRA_DUNGEON_BOSS.
#        Default:     1 / 1

Playerbots.TargetSelection.SkipBossFlag = 1
Playerbots.TargetSelection.SkipDungeonBoss = 1

#
#    Playerbots.TargetSelection.SkipCritters
#        Description: Skip CREATURE_TYPE_CRITTER.
#        Default:     1

Playerbots.TargetSelection.SkipCritters = 1

#
#    Playerbots.TargetSelection.SkipCombatWithOthers
#        Description: Skip creatures in combat with a unit that is not this bot (reduces steal-tag pulls).
#        Default:     1

Playerbots.TargetSelection.SkipCombatWithOthers = 1

#
#    Playerbots.TargetSelection.RequireLos
#        Description: Require line of sight to the creature (stricter; may reduce valid targets).
#        Default:     0

Playerbots.TargetSelection.RequireLos = 0
